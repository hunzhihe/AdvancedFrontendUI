/.vscode
/Content
/DerivedDataCache
/Intermediate
/Saved
.vs/

# 编译后的目标文件
*.slo
*.lo
*.o
*.obj

# 预编译头文件
*.gch
*.pch

# 编译后的动态库
*.so
*.dylib
*.dll

# Fortran 模块文件
*.mod

# 编译后的静态库
*.lai
*.la
*.a
*.lib

# 可执行文件
*.exe
*.out
*.app
*.ipa

# 引擎可能生成的工程文件
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# 预编译资源
SourceArt/**/*.png
SourceArt/**/*.tga

# 二进制文件
Binaries/*
Plugins/*/Binaries/*

# 构建目录
Build/*

# 保留 PakBlacklist-<编译配置>.txt 文件
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# 不要忽略 Build 目录下的图标文件
!Build/**/*.ico

# 地图的内建数据
*_BuiltData.uasset

# 编辑器生成的配置文件
Saved/*

# 引擎使用的编译源文件
Intermediate/*
Plugins/*/Intermediate/*

# 编辑器使用的缓存文件
DerivedDataCache/*

# ==========================================
# 额外需要忽略的资源文件夹（来自第二个 .gitignore）
# ==========================================
**/BlackAlder
**/Landscape
**/MedievalDungeon
**/Megascans
**/StarterContent
**/Assets